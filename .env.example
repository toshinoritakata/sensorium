# DigiKey Product Information API（pnpm ingest:digikey で使用）。
# developer.digikey.com で App を作成し Product Information API を有効化して発行する。
# このファイルをコピーして .env を作り、値を埋める（.env は .gitignore 済み・コミットされない）:
#   cp .env.example .env
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# 任意: 本番は未設定でよい（既定 https://api.digikey.com）。サンドボックスを使うとき:
#   DIGIKEY_API_BASE=https://sandbox-api.digikey.com
# DIGIKEY_API_BASE=
# DIGIKEY_LOCALE_SITE=US
# DIGIKEY_LOCALE_LANGUAGE=en
# DIGIKEY_LOCALE_CURRENCY=USD

# ANTHROPIC_API_KEY は .zshrc 側で export 済み。.env に入れたい場合はここにも書ける。
# ANTHROPIC_API_KEY=
